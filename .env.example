# Sentry MSSQL Database
# Server name — usually MACHINENAME\SQLEXPRESS for local SQL Express
SENTRY_DB_SERVER=DESKTOP-YOURSERVER\SQLEXPRESS

SENTRY_DB_NAME=SentryLocal

# Leave blank to use Windows Authentication (recommended for local SQL Express)
# Fill in only if using SQL Server Authentication
SENTRY_DB_USER=
SENTRY_DB_PASS=

# API Key — used as Bearer token for all requests
# Change this to a long random string before deploying
API_KEY=change-me-to-something-secret



# Port for the Node.js server (default: 3000)
PORT=3000
